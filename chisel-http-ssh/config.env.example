# Copy this file to config.env and fill values there:
#   cp config.env.example config.env
#   chmod 600 config.env
#
# Scripts automatically read ./config.env from the same chisel-http-ssh
# directory. Override with --config PATH or CHISEL_HTTP_SSH_CONFIG=PATH.
#
# Quote values. Do not commit config.env after filling real secrets.

# Chisel auth. Prefer separate user/password fields.
CHISEL_AUTH_USER=""
CHISEL_AUTH_PASS=""

# Optional full auth override. If set, it wins over CHISEL_AUTH_USER/PASS.
# CHISEL_AUTH="USER:PASS"

# Platform HTTP forward URL used by local_start_chisel.sh.
PLATFORM_URL=""

# SSH identity and local SSH alias used by local_config_chisel.sh and sshfs.
SSH_KEY="${HOME}/.ssh/id_ed25519"
HOST_ALIAS="worker-0-chisel"
LOCAL_BIND="127.0.0.1"
LOCAL_PORT="2222"
SSH_USER="root"

# Remote paths and ports.
REMOTE_HOME="/public/home/tangyu408"
REMOTE_PATH="/public/home/tangyu408"
REMOTE_SCRIPT_DIR="/public/home/tangyu408/chisel-http-ssh"
REMOTE_SSH_HOST="127.0.0.1"
REMOTE_SSH_PORT="22"
CHISEL_PORT="8080"
SSHD_PORT="22"

# Public key for remote_config_chisel.sh.
# Put the one-line local public key here, or point to a file that exists
# in the environment where remote_config_chisel.sh runs.
LOCAL_PUBKEY=""
LOCAL_PUBKEY_FILE=""

# Local sshfs/Codex mount settings.
MOUNT_POINT="remote-home"
AUTO_MOUNT="1"
ENABLE_NETWORK="1"
CODEX_SANDBOX_MODE="workspace-write"
